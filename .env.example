# Copie ce fichier en .env (qui est gitignoré) et adapte les valeurs.
#
# docker compose lit automatiquement .env à côté du compose.yml.

# Mot de passe Neo4j (utilisateur 'neo4j')
NEO4J_PASSWORD=neo4flix123

# Secret HMAC partagé entre les 4 services pour signer/vérifier les JWT.
# DOIT faire au moins 32 caractères.
NEO4FLIX_JWT_SECRET=change-me-please-this-is-not-a-prod-secret-32chars
